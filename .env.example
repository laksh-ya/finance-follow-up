# =============================================================================
# Finance Collections Agent — Environment Variables
# Copy to `.env` and fill in your values. See SETUP_REAL.md for details.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. APP
# -----------------------------------------------------------------------------
APP_NAME="Finance Collections Agent"
DEBUG=true
# X-API-Key required for every /api/* call
API_KEY=dev-secret-key
# Comma-separated CORS origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# 2. DATA SOURCE — "csv" or "sheets"
# -----------------------------------------------------------------------------
# csv    = Upload CSV files, process, download results (standalone)
# sheets = Live sync with Google Sheets (two-way writeback)
DATA_SOURCE=csv
HUMAN_IN_LOOP=true
AUTO_DISPATCH=true

# -----------------------------------------------------------------------------
# 3. LLM
# -----------------------------------------------------------------------------
# Get a free Groq key: https://console.groq.com/keys
LLM__PROVIDER=groq
LLM__MODEL=groq/llama-3.1-8b-instant
LLM__API_KEY=
LLM__TEMPERATURE=0.3
LLM__MAX_TOKENS=1024
LLM__CONFIDENCE_THRESHOLD=0.75

# Alternative providers (uncomment one):
# LLM__PROVIDER=gemini
# LLM__MODEL=gemini/gemini-1.5-flash-latest
#
# LLM__PROVIDER=openai
# LLM__MODEL=openai/gpt-4o-mini
#
# LLM__PROVIDER=ollama
# LLM__MODEL=ollama/llama3.1
# LLM__BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# 4. EMAIL DELIVERY
# -----------------------------------------------------------------------------
# mock     = logs only, no network (default for dev)
# sandbox  = SMTP send to Mailtrap (safe preview inbox)
# live     = Resend API (real delivery, needs verified domain)
EMAIL_MODE=mock
EMAIL_FROM=Finance Collections <collections@example.com>

# Mailtrap (sandbox) — https://mailtrap.io
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=

# Resend (live) — https://resend.com
RESEND_API_KEY=
RESEND_FROM=Finance Collections <onboarding@resend.dev>

# Generic SMTP override (Gmail/Zoho/etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=<app-password>
# SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# 5. REDIS / CELERY
# -----------------------------------------------------------------------------
# CELERY_EAGER=true runs tasks inline (no Redis/worker needed)
CELERY_EAGER=true
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# 6. DATABASE
# -----------------------------------------------------------------------------
# Default: SQLite (no setup needed)
# Postgres: postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./data/finance.db

# -----------------------------------------------------------------------------
# 7. GOOGLE SHEETS (optional — only for DATA_SOURCE=sheets)
# -----------------------------------------------------------------------------
SHEETS_ENABLED=false
SHEETS_CREDENTIALS_PATH=credentials.json
SHEETS_INVOICE_ID=
SHEETS_AUDIT_ID=

# -----------------------------------------------------------------------------
# 8. LANGFUSE (LLM observability — free 50k events/month)
# -----------------------------------------------------------------------------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# 9. RATE LIMITS
# -----------------------------------------------------------------------------
MAX_EMAILS_PER_MINUTE=10
MAX_LLM_CALLS_PER_MINUTE=20

# -----------------------------------------------------------------------------
# 10. FRONTEND
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=dev-secret-key
